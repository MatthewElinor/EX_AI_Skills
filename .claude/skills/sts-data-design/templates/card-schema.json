{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CardData",
  "description": "Schema for card data in Slay the Spire-like card game",
  "type": "object",
  "required": ["id", "name", "type", "cost", "effects"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier in snake_case",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "name": {
      "type": "string",
      "description": "Display name in Chinese"
    },
    "type": {
      "type": "string",
      "enum": ["Attack", "Skill", "Power", "Status", "Curse"],
      "description": "Card type category"
    },
    "rarity": {
      "type": "string",
      "enum": ["Common", "Uncommon", "Rare", "Legendary"],
      "default": "Common"
    },
    "cost": {
      "type": "integer",
      "minimum": -1,
      "description": "Energy cost, -1 for X cost"
    },
    "target": {
      "type": "string",
      "enum": ["Self", "SingleEnemy", "AllEnemies", "None"],
      "default": "SingleEnemy"
    },
    "effects": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Effect"
      },
      "description": "List of effects when played"
    },
    "description": {
      "type": "string",
      "description": "Card description in Chinese"
    },
    "upgrade": {
      "$ref": "#/definitions/Upgrade",
      "description": "Upgrade modifications"
    },
    "keywords": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Search keywords"
    },
    "art_path": {
      "type": "string",
      "description": "Path to card art image"
    },
    "exhausts": {
      "type": "boolean",
      "default": false,
      "description": "Whether card exhausts when played"
    },
    "ethereal": {
      "type": "boolean",
      "default": false,
      "description": "Exhausts if in hand at end of turn"
    },
    "innate": {
      "type": "boolean",
      "default": false,
      "description": "Always in opening hand"
    }
  },
  "definitions": {
    "Effect": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["Damage", "Block", "ApplyBuff", "ApplyDebuff", "Draw", "GainEnergy", "Heal", "Discard", "Exhaust", "Special"]
        },
        "value": {
          "type": "integer",
          "description": "Primary value (damage amount, block amount, etc.)"
        },
        "times": {
          "type": "integer",
          "default": 1,
          "description": "Number of times to apply effect"
        },
        "buff_type": {
          "type": "string",
          "enum": ["Strength", "Dexterity", "Focus", "Artifact", "Intangible", "Buffer"],
          "description": "Type of buff to apply"
        },
        "debuff_type": {
          "type": "string",
          "enum": ["Vulnerable", "Weak", "Poison", "Burn", "Dazed", "Entangle"],
          "description": "Type of debuff to apply"
        },
        "target": {
          "type": "string",
          "enum": ["Self", "SelectedEnemy", "AllEnemies", "RandomEnemy"]
        }
      }
    },
    "Upgrade": {
      "type": "object",
      "properties": {
        "name_suffix": {
          "type": "string",
          "description": "Suffix added to name when upgraded, usually '+'"
        },
        "cost_change": {
          "type": "integer",
          "description": "Change to energy cost"
        },
        "damage_bonus": {
          "type": "integer",
          "description": "Bonus damage added"
        },
        "block_bonus": {
          "type": "integer",
          "description": "Bonus block added"
        },
        "effect_bonus": {
          "type": "integer",
          "description": "Bonus to effect value"
        },
        "additional_effects": {
          "type": "array",
          "items": { "$ref": "#/definitions/Effect" },
          "description": "Effects added on upgrade"
        }
      }
    }
  }
}